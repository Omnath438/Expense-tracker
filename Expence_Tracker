from datetime import date


def add_expense():
    amount = input("Enter amount: ")
    category = input("Enter category: ")

    today = date.today()

    with open("expenses.txt", "a") as file:
        file.write(f"{today},{amount},{category}\n")

    print("Expense added successfully!")

def view_expenses():
    try:
        with open("expenses.txt", "r") as file:
            expenses = file.readlines()

        if not expenses:
            print("No expenses found.")
            return

        print("\n===== EXPENSES =====")

        for expense in expenses:
            parts = expense.strip().split(",")

            if len(parts) == 3:
                expense_date, amount, category = parts
                print(f"{expense_date} | Rs.{amount} | {category}")

            elif len(parts) == 2:
                amount, category = parts
                print(f"No Date | Rs.{amount} | {category}")

    except FileNotFoundError:
        print("No expense file found.")


def total_spending():
    total = 0

    try:
        with open("expenses.txt", "r") as file:
            for line in file:
                parts = line.strip().split(",")

                if len(parts) == 3:
                    _, amount, _ = parts
                else:
                    amount, _ = parts

                total += float(amount)

        print(f"\nTotal Spending: Rs.{total}")

    except FileNotFoundError:
        print("No expense file found.")


def set_allowance():
    allowance = input("Enter allowance: ")

    with open("allowance.txt", "w") as file:
        file.write(allowance)

    with open("allowance_history.txt", "a") as file:
        file.write(f"Set Allowance Rs.{allowance}\n")

    print("Allowance saved!")

def view_allowance():
    try:
        with open("allowance.txt", "r") as file:
            allowance = float(file.read())

        print(f"\nCurrent Allowance: Rs.{allowance}")

    except FileNotFoundError:
        print("No allowance set yet.")

def add_allowance():
    try:
        with open("allowance.txt", "r") as file:
            allowance = float(file.read())
    except FileNotFoundError:
        allowance = 0

    amount = float(input("Enter amount to add: "))
    allowance += amount

    with open("allowance.txt", "w") as file:
        file.write(str(allowance))

    with open("allowance_history.txt", "a") as file:
        file.write(f"Added Rs.{amount}\n")

    print(f"New Allowance: Rs.{allowance}")


def reduce_allowance():
    try:
        with open("allowance.txt", "r") as file:
            allowance = float(file.read())
    except FileNotFoundError:
        print("Please set allowance first.")
        return

    amount = float(input("Enter amount to reduce: "))
    allowance -= amount

    with open("allowance.txt", "w") as file:
        file.write(str(allowance))

    with open("allowance_history.txt", "a") as file:
        file.write(f"Reduced Rs.{amount}\n")

    print(f"New Allowance: Rs.{allowance}")


def remaining_money():
    try:
        with open("allowance.txt", "r") as file:
            allowance = float(file.read())

        total = 0

        try:
            with open("expenses.txt", "r") as file:
                for line in file:
                    parts = line.strip().split(",")

                    if len(parts) == 3:
                        _, amount, _ = parts
                    else:
                        amount, _ = parts

                    total += float(amount)

        except FileNotFoundError:
            pass

        remaining = allowance - total

        print(f"Allowance: Rs.{allowance}")
        print(f"Spent: Rs.{total}")
        print(f"Remaining: Rs.{remaining}")

        if remaining < 0:
            print("WARNING! You exceeded your allowance!")

    except FileNotFoundError:
        print("Please set allowance first.")


def search_expense():
    keyword = input("Enter category to search: ")

    found = False

    try:
        with open("expenses.txt", "r") as file:
            for line in file:
                if keyword.lower() in line.lower():
                    print(line.strip())
                    found = True

        if not found:
            print("No matching expense found.")

    except FileNotFoundError:
        print("No expense file found.")


def expense_history():
    try:
        with open("expenses.txt", "r") as file:
            expenses = file.readlines()

        if not expenses:
            print("No expense history found.")
            return

        print("\n===== EXPENSE HISTORY =====")

        for i, expense in enumerate(expenses, start=1):
            print(f"{i}. {expense.strip()}")

    except FileNotFoundError:
        print("No expense history found.")


def allowance_history():
    try:
        with open("allowance_history.txt", "r") as file:
            history = file.readlines()

        if not history:
            print("No allowance history found.")
            return

        print("\n===== ALLOWANCE HISTORY =====")

        for line in history:
            print(line.strip())

    except FileNotFoundError:
        print("No allowance history found.")


